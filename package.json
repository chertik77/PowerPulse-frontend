{
  "name": "power-pulse",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write ./src",
    "format:check": "prettier --check ./src",
    "steiger:check": "steiger ./src",
    "graphql:generate": "graphql-codegen --config ./src/shared/lib/graphql/codegen-config.ts",
    "lint": "eslint -f mo && bun run steiger:check",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@next/env": "^16.2.4",
